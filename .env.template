# ============================================================================
# ADSBuddy — required-to-boot settings only.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Every other knob (radio URL, ingest cadence, alert rules, etc.) lives in the
# Postgres `settings` table and is edited from the admin UI.
# ============================================================================

# -- Web app -----------------------------------------------------------------
# Port the web app listens on, bound only to localhost + the tailnet IP below.
ADSBUDDY_PORT=8000

# Optional: pre-configure your adsb-im radio so it works on first boot without
# visiting the admin UI. Used only on initial setup to seed the "Local radio"
# source (manage it later under Admin -> Sources). Blank = set it in the admin UI.
# e.g. http://adsb.local:8080  or  http://100.107.148.119:8080
ADSBUDDY_RADIO_URL=

# Station ("buddy") location. Uses the same env names as adsb-feeder-image, so
# co-deploying on an adsb-im box can share the values. When set, these are applied
# to the receiver location on every boot (env wins over the admin UI); leave blank
# to set it under Admin -> System instead. ADSBUDDY_LAT/LON/ALT_M also accepted.
FEEDER_LAT=
FEEDER_LONG=
FEEDER_ALT_M=

# Where to bind the web port. Default 127.0.0.1 = localhost only (reach the
# tailnet via Tailscale Serve). Set 0.0.0.0 to reach it directly on the LAN /
# tailnet (e.g. an appliance), or a specific interface IP. Don't expose "open"
# mode on an untrusted network.
ADSBUDDY_BIND=127.0.0.1

# Random string used to sign session cookies. Rotate to log everyone out.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
ADSBUDDY_SECRET_KEY=please-generate-a-random-string-and-paste-here

# -- First-run admin bootstrap -----------------------------------------------
# On first boot, if no admin user exists, one is created from these.
# After bootstrap you can (and should) change the password in the admin UI.
ADSBUDDY_ADMIN_USERNAME=admin
ADSBUDDY_ADMIN_PASSWORD=changeme-on-first-login

# -- Postgres ----------------------------------------------------------------
# These credentials are consumed by both the Postgres container (to init the
# database) and the app (to connect to it). POSTGRES_HOST=db matches the
# service name in docker-compose.yml.
POSTGRES_USER=adsbuddy
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_DB=adsbuddy
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -- Access mode -------------------------------------------------------------
# "MultiUser" (default): guest / user / admin with logins.
# "open": NO login at all — every visitor has full admin. Use ONLY on a trusted
#   single appliance (e.g. an adsb-im Pi) reachable on your tailnet/LAN, never
#   on a shared or public network. The UI shows an "open mode" banner.
ADSBUDDY_MODE=MultiUser

# -- Test mode (off by default) ----------------------------------------------
# When set to "1", exposes /test/login for Playwright/E2E suites to mint a
# session cookie without driving the real login form. NEVER enable in prod.
ADSBUDDY_TEST_MODE=0
