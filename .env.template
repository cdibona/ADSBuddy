# ============================================================================
# ADSBuddy — required-to-boot settings only.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Every other knob (radio URL, ingest cadence, alert rules, etc.) lives in the
# Postgres `settings` table and is edited from the admin UI.
# ============================================================================

# -- Web app -----------------------------------------------------------------
# Port the web app listens on, bound only to localhost + the tailnet IP below.
ADSBUDDY_PORT=8000

# This host's Tailscale IP. The Docker port map binds to 127.0.0.1 and this IP
# so the app is reachable on localhost and across the tailnet, but never on a
# public interface. Run `tailscale ip -4` to find yours.
ADSBUDDY_TAILNET_IP=100.125.0.85

# Random string used to sign session cookies. Rotate to log everyone out.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
ADSBUDDY_SECRET_KEY=please-generate-a-random-string-and-paste-here

# -- First-run admin bootstrap -----------------------------------------------
# On first boot, if no admin user exists, one is created from these.
# After bootstrap you can (and should) change the password in the admin UI.
ADSBUDDY_ADMIN_USERNAME=admin
ADSBUDDY_ADMIN_PASSWORD=changeme-on-first-login

# -- Postgres ----------------------------------------------------------------
# These credentials are consumed by both the Postgres container (to init the
# database) and the app (to connect to it). POSTGRES_HOST=db matches the
# service name in docker-compose.yml.
POSTGRES_USER=adsbuddy
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_DB=adsbuddy
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -- Test mode (off by default) ----------------------------------------------
# When set to "1", exposes /test/login for Playwright/E2E suites to mint a
# session cookie without driving the real login form. NEVER enable in prod.
ADSBUDDY_TEST_MODE=0
